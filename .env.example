PORT=3030
APP_BASE_URL=http://localhost:3030
# Optional defaults if you don't want to enter these in /admin:
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:3030/auth/callback
# ESPN provider defaults (optional)
ESPN_LEAGUE_ID=
ESPN_SEASON=
ESPN_WEEK=current
ESPN_SWID=
ESPN_S2=
# Sleeper provider defaults (optional)
SLEEPER_LEAGUE_ID=
SLEEPER_SEASON=
SLEEPER_WEEK=current
# Set to true to start in mock mode without Yahoo auth:
MOCK_MODE=true
# Optional admin key for protecting admin/config routes
ADMIN_API_KEY=
# Optional read key for /overlay and /events public routes
OVERLAY_API_KEY=
# Optional: persist secrets/tokens in macOS Keychain when available
USE_OS_KEYCHAIN=false
